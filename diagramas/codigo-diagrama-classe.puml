      IRoutesProfessor <|.. RoutesProfessor
      IRoutesAluno <|.. RoutesAluno
      IRoutesAula <|.. RoutesAula
      IRoutesExercicio <|.. RoutesExercicio
      IRoutesMateria <|.. RoutesMateria
    }
