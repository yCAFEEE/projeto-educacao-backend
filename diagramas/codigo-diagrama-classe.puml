@startuml
skinparam classAttributeIconSize 0
allow_mixing
left to right direction

package "Projeto"{
  package "Model"{
    package "Persistence Layer"{
      Interface ProfessorDAO{
        + salvar(professor : Professor) : boolean
        + alterar(professor : Professor) : boolean
        + deletar(professor : Professor) : boolean
        + consultar() : Professor[]
        + consultarById(professor : Professor) : Professor
      }
      Class ProfessorDAO_MongoDB{
        + salvar(professor : Professor) : boolean
        + alterar(professor : Professor) : boolean
        + deletar(professor : Professor) : boolean
        + consultar() : Professor[]
        + consultarById(professor : Professor) : Professor
      }
      
      Interface AlunoDAO{
        + salvar(aluno : Aluno) : boolean
        + alterar(aluno : Aluno) : boolean
        + deletar(aluno : Aluno) : boolean
        + consultar() : Aluno[]
        + consultarById(aluno : Aluno) : Aluno
      }
      Class AlunoDAO_MongoDB{
        + salvar(aluno : Aluno) : boolean
        + alterar(aluno : Aluno) : boolean
        + deletar(aluno : Aluno) : boolean
        + consultar() : Aluno[]
        + consultarById(aluno : Aluno) : Aluno
      }
      
      Interface AulaDAO{
        + salvar(aula : Aula) : boolean
        + alterar(aula : Aula) : boolean
        + deletar(aula : Aula) : boolean
        + consultar() : Aula[]
        + consultarById(aula : Aula) : Aula
      }

      Class AulaDAO_MongoDB{
        + salvar(aula : Aula) : boolean
        + alterar(aula : Aula) : boolean
        + deletar(aula : Aula) : boolean
        + consultar() : Aula[]
        + consultarById(aula : Aula) : Aula
      }
      
      Interface ExercicioDAO{
        + salvar(exercicio : Exercicio) : boolean
        + alterar(exercicio : Exercicio) : boolean
        + deletar(exercicio : Exercicio) : boolean
        + consultar() : Exercicio[]
        + consultarById(exercicio : Exercicio) : Exercicio
      }
      Class ExercicioDAO_MongoDB{
        + salvar(exercicio : Exercicio) : boolean
        + alterar(exercicio : Exercicio) : boolean
        + deletar(exercicio : Exercicio) : boolean
        + consultar() : Exercicio[]
        + consultarById(exercicio : Exercicio) : Exercicio
      }
      
      Interface MateriaDAO{
        + salvar(materia : Materia) : boolean
        + alterar(materia : Materia) : boolean
        + deletar(materia : Materia) : boolean
        + consultar() : Materia[]
        + consultarById(materia : Materia) : Materia
      }
      Class MateriaDAO_MongoDB{
        + salvar(materia : Materia) : boolean
        + alterar(materia : Materia) : boolean
        + deletar(materia : Materia) : boolean
        + consultar() : Materia[]
        + consultarById(materia : Materia) : Materia
      }
      
      ProfessorDAO <|.. ProfessorDAO_MongoDB
      AlunoDAO <|.. AlunoDAO_MongoDB
      AulaDAO <|.. AulaDAO_MongoDB
      ExercicioDAO <|.. ExercicioDAO_MongoDB
      MateriaDAO <|.. MateriaDAO_MongoDB
    }
    
    package "Object"{
      Class Pessoa{
        - id : Object
        - nome : String
        - usuario: String
        - email: String
        - senha: String
        + setId(id : Object) : boolean
        + getId() : Object
        + setNome(nome : String) : boolean
        + getNome(id : Object) : String
        + setUsuario(usuario : String) : boolean
        + getUsuario(id : Object) : String
        + setEmail(email : String) : boolean
        + getEmail(id : Object) : String
        + setSenha(senha : String) : boolean
        + getSenha(id : Object) : String
        + getPessoas() : Pessoa[]
        + getPessoaById(id : Object) : Pessoa
        + login(email_usuario: String, senha: String): boolean
      }
      
      Class Professor{
        + getProfessores() : Professor[]
        + criarAula(aula : Aula) : boolean
        + deletarAula() : boolean
        + editarAula() : boolean
        + criarExercicio(exercicio : Exercicio) : boolean
        + deletarExercicio() : boolean
        + editarExercicio() : boolean
        + criarMateria(materia : Materia) : boolean
        + deletarMateria() : boolean
        + editarMateria() : boolean
      }
      
      Class Aluno{
        + getAlunos() : Aluno[]
        + getAulas() : Aula[] 
        + getExercicios() : Exercicio[] 
      }
      
      Class Exercicio{
        - id : Object
        - titulo: String
        - desc: String
        - enunciado: String
        - alternativas: String[]
        + setId(id : Object) : boolean
        + getId() : Object
        + setTitulo(titulo : String) : boolean
        + getTitulo() : String
        + setDesc(desc : String) : boolean
        + getDesc() : String
        + setEnunciado(enunciado : String) : boolean
        + getEnunciado() : String
        + setAlternativas(alternativas : String[]) : boolean
        + getAlternativas(id : Object) : String[]
      }

      Class Aula{
        - id : Object
        - titulo: String
        - desc: String
        - url: String
        - explicacao: String
        + setId(id : Object) : boolean
        + getId() : Object
        + setTitulo(titulo : String) : boolean
        + getTitulo(id : Object) : String
        + setDesc(desc : String) : boolean
        + getDesc(id : Object) : String
        + setUrl(url : String) : boolean
        + getUrl(id : Object) : String
        + setExplicacao(explicacao : String) : boolean
        + getExplicacao(id : Object) : String
        + getExercicios(): Exercicio[]
      }
      
      Class Materia{
        - id : Object
        - nome: String
        + setId(id : Object) : boolean
        + getId() : Object
        + setNome(nome : String) : boolean
        + getNome(id : Object) : String
        + getAulas(id : Object) : Aula[]
      }
      
      Pessoa <|-- Professor
      Pessoa <|-- Aluno
      Professor "1..*" o-- "1..*" Materia
      Professor "1..*" -- "0..*" Aula
      Aluno "0..*" -- "0..*" Aula
      Aluno "0..*" -- "0..*" Exercicio
      Aula "1..1" --- "0..*" Exercicio
      Professor "1..*" -- "0..*" Exercicio
      Aula "1..*" o-- "1..1" Materia
    }
  }
  
