      Class RoutesProfessor{
        + post(uri : String, acao : Object) : Object <</professor>>
        + get(uri : String, acao : Object) : Object <</professor>>
        + get(uri : String, acao : Object) : Object <</professor/:id>>
        + put(uri : String, acao : Object) : Object <</professor/:id>>
        + delete(uri : String, acao : Object) : Object <</professor/:id>>
      }
      
      Class RoutesAula{
        + post(uri : String, acao : Object) : Object <</aula>>
        + get(uri : String, acao : Object) : Object <</aula>>
        + get(uri : String, acao : Object) : Object <</aula/:id>>
        + put(uri : String, acao : Object) : Object <</aula/:id>>
        + delete(uri : String, acao : Object) : Object <</aula/:id>>
      }
    
      Class RoutesExercicio{
        + post(uri : String, acao : Object) : Object <</exercicio>>
        + get(uri : String, acao : Object) : Object <</exercicio>>
        + get(uri : String, acao : Object) : Object <</exercicio/:id>>
        + put(uri : String, acao : Object) : Object <</exercicio/:id>>
